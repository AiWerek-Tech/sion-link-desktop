{
  "name": "sion-link-desktop",
  "version": "1.0.0",
  "description": "SION Link Native Desktop Companion",
  "main": "out/main.js",
  "author": "AiWerek Tech",
  "scripts": {
    "build": "tsc",
    "predev": "npm run build",
    "dev": "concurrently \"tsc -w\" \"electron .\"",
    "start": "electron .",
    "agent:publish": "dotnet publish ../sion-powerpoint-agent/Sion.PowerPoint.Agent.csproj -c Release -r win-x64 --self-contained true",
    "test:powerpoint-agent:manual": "npm run agent:publish && node scripts/test-powerpoint-agent-manual.js",
    "test:bridge-ui": "node scripts/bridge-ui-contract.test.js",
    "dist": "npm run build && npm run agent:publish && electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "concurrently": "^8.2.2"
  },
    "build": {
    "appId": "tech.aiwerek.sionlink.desktop",
    "productName": "SION Link Desktop",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "src/renderer/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../sion-powerpoint-agent/bin/Release/net8.0-windows/win-x64/publish",
        "to": "powerpoint-agent",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "SION-Link-Desktop-${version}-Setup.${ext}"
    },
    "nsis": {
      "artifactName": "SION-Link-Desktop-${version}-Setup.${ext}",
      "shortcutName": "SION Link Desktop",
      "uninstallDisplayName": "SION Link Desktop",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "displayLanguageSelector": false,
      "installerLanguages": [
        "id_ID"
      ],
      "language": "1057"
    }
  }
}
